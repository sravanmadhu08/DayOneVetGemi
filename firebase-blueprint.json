{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "bio": { "type": "string" },
        "specialty": { "type": "string" },
        "institution": { "type": "string" },
        "quizStats": {
          "type": "object",
          "properties": {
            "completed": { "type": "integer" },
            "averageScore": { "type": "number" },
            "lastScore": { "type": "number" },
            "totalQuestions": { "type": "integer" },
            "correctAnswers": { "type": "integer" }
          }
        },
        "progress": {
          "type": "object",
          "description": "Progress in modules and quizzes"
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "Study card with front and back content",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the creator (null for system cards)" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "deck": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["front", "back"]
    },
    "FlashcardProgress": {
      "title": "Flashcard Progress",
      "description": "User's SRS progress for a specific flashcard",
      "type": "object",
      "properties": {
        "cardId": { "type": "string" },
        "interval": { "type": "number" },
        "ease": { "type": "number" },
        "nextReview": { "type": "number", "description": "Timestamp" },
        "lastReviewed": { "type": "number", "description": "Timestamp" },
        "consecutiveCorrect": { "type": "integer" }
      },
      "required": ["cardId", "nextReview"]
    },
    "StudyModule": {
      "title": "Study Module",
      "description": "Educational content module",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string", "description": "Markdown content" },
        "order": { "type": "integer" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" }
            },
            "required": ["title", "content"]
          }
        }
      },
      "required": ["title", "content"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Knowledge assessment",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "integer" },
              "explanation": { "type": "string" },
              "sourceId": { "type": "string", "description": "Reference to a PdfDocument id" },
              "species": { "type": "array", "items": { "type": "string" } },
              "system": { "type": "string" }
            }
          }
        }
      },
      "required": ["title", "questions"]
    },
    "Question": {
       "title": "Practice Question",
       "description": "Individual practice question in the global pool",
       "type": "object",
       "properties": {
         "userId": { "type": "string", "description": "Creator ID (null for system questions)" },
         "question": { "type": "string" },
         "options": { "type": "array", "items": { "type": "string" } },
         "correctAnswer": { "type": "integer" },
         "explanation": { "type": "string" },
         "species": { "type": "array", "items": { "type": "string" } },
         "system": { "type": "string" },
         "sourceId": { "type": "string", "description": "Reference to a PdfDocument id" },
         "createdAt": { "type": "string", "format": "date-time" }
       },
       "required": ["question", "options", "correctAnswer", "species", "system"]
    },
    "QuizHistory": {
      "title": "Quiz Result",
      "description": "Historical quiz performance data",
      "type": "object",
      "properties": {
        "score": { "type": "number" },
        "total": { "type": "integer" },
        "correct": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" },
        "system": { "type": "string" },
        "species": { "type": "string" }
      },
      "required": ["score", "total", "correct", "timestamp"]
    },
    "CompletedPracticeQuestion": {
      "title": "Completed Practice Question",
      "description": "A record of a practice question answered correctly",
      "type": "object",
      "properties": {
        "questionId": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["questionId", "completedAt"]
    },
    "ModuleProgress": {
      "title": "Module Progress",
      "description": "User's progress through a specific study module",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "currentSection": { "type": "integer" },
        "totalSections": { "type": "integer" },
        "completed": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" },
        "lastReadAt": { "type": "string", "format": "date-time" }
      },
      "required": ["moduleId", "currentSection", "totalSections"]
    },
    "PdfDocument": {
      "title": "PDF Document",
      "description": "Metadata for a study PDF",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Uploader ID (null for system files)" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "size": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "createdAt"]
    },
    "Guideline": {
      "title": "Clinical Guideline",
      "description": "Veterinary clinical guidelines",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "summary": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "summary"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/flashcardProgress/{cardId}": {
      "schema": "FlashcardProgress",
      "description": "User's SRS progress for cards"
    },
    "/users/{userId}/quizHistory/{historyId}": {
      "schema": "QuizHistory",
      "description": "Historical quiz results for analytics"
    },
    "/users/{userId}/completedPracticeQuestions/{questionId}": {
      "schema": "CompletedPracticeQuestion",
      "description": "Correctly answered practice questions"
    },
    "/users/{userId}/moduleProgress/{moduleId}": {
      "schema": "ModuleProgress",
      "description": "Detailed progress tracking for individual modules"
    },
    "/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Flashcards repository"
    },
    "/modules/{moduleId}": {
      "schema": "StudyModule",
      "description": "Study modules"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quizzes for modules or cases"
    },
    "/pdfs/{pdfId}": {
      "schema": "PdfDocument",
      "description": "Library of PDF study materials"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Practice questions library"
    },
    "/guidelines/{guidelineId}": {
      "schema": "Guideline",
      "description": "Clinical guidelines"
    }
  }
}

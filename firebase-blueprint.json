{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user specific information and overall progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" },
        "isAdmin": { "type": "boolean" },
        "bio": { "type": "string" },
        "specialty": { "type": "string" },
        "institution": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "subscriptionUntil": { "type": "number" },
        "progress": { "type": "object" },
        "quizStats": { "type": "object" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "Global flashcards for studying",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "deck": { "type": "string" },
        "userId": { "type": "string" },
        "tags": { "type": "array" },
        "createdAt": { "type": "number" }
      },
      "required": ["front", "back", "deck", "createdAt"]
    },
    "FlashcardProgress": {
      "title": "Flashcard Progress",
      "description": "SRS data for a specific card for a user",
      "type": "object",
      "properties": {
        "cardId": { "type": "string" },
        "interval": { "type": "number" },
        "ease": { "type": "number" },
        "nextReview": { "type": "number" },
        "lastReviewed": { "type": "number" },
        "consecutiveCorrect": { "type": "number" }
      },
      "required": ["cardId", "interval", "ease", "nextReview", "consecutiveCorrect"]
    },
    "StudyModule": {
      "title": "Study Module",
      "description": "Rich content for learning clinical concepts",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "order": { "type": "number" },
        "sections": { "type": "array" }
      },
      "required": ["title", "category", "content", "order"]
    },
    "Question": {
      "title": "Question",
      "description": "Quiz questions for testing knowledge",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array" },
        "correctAnswer": { "type": "number" },
        "explanation": { "type": "string" },
        "species": { "type": "array" },
        "system": { "type": "string" },
        "sourceId": { "type": "string" }
      },
      "required": ["question", "options", "correctAnswer", "explanation", "species", "system"]
    },
    "PdfDocument": {
      "title": "PDF Document",
      "description": "Library of PDF resources",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "size": { "type": "string" },
        "url": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "author", "url"]
    },
    "Guideline": {
      "title": "Guideline",
      "description": "Clinical practice guidelines",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "content", "category"]
    },
    "Resource": {
      "title": "Resource",
      "description": "External veterinary resources",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "url", "type", "order"]
    },
    "ModuleProgress": {
      "title": "Module Progress",
      "description": "Detailed progress tracking for a study module",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "currentSection": { "type": "number" },
        "totalSections": { "type": "number" },
        "completed": { "type": "boolean" }
      },
      "required": ["moduleId", "currentSection", "totalSections", "completed"]
    },
    "QuizResult": {
      "title": "Quiz Result",
      "description": "Historical record of a completed quiz session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "correct": { "type": "number" },
        "timestamp": { "type": "object" },
        "system": { "type": "string" },
        "species": { "type": "string" }
      },
      "required": ["score", "total", "correct", "timestamp", "system", "species"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and progress"
    },
    "/users/{userId}/flashcardProgress/{cardId}": {
      "schema": "FlashcardProgress",
      "description": "User specific SRS data for flashcards"
    },
    "/users/{userId}/moduleProgress/{moduleId}": {
      "schema": "ModuleProgress",
      "description": "Detailed module progress"
    },
    "/users/{userId}/quizHistory/{quizId}": {
      "schema": "QuizResult",
      "description": "User quiz history"
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Global question pool"
    },
    "/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Global flashcard pool"
    },
    "/modules/{moduleId}": {
      "schema": "StudyModule",
      "description": "Study modules"
    },
    "/pdfs/{pdfId}": {
      "schema": "PdfDocument",
      "description": "PDF library"
    },
    "/guidelines/{guideId}": {
      "schema": "Guideline",
      "description": "Clinical guidelines"
    },
    "/resources/{resId}": {
      "schema": "Resource",
      "description": "External resources"
    }
  }
}

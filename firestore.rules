rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'sravan96mufc@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validation Helpers ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is number;
    }

    function isValidFlashcardProgress(data) {
      return data.keys().hasAll(['cardId', 'interval', 'ease', 'nextReview', 'consecutiveCorrect', 'lastReviewed']) &&
             data.cardId is string &&
             data.interval is number &&
             data.ease is number &&
             data.nextReview is number &&
             data.consecutiveCorrect is number &&
             data.lastReviewed is number;
    }

    function isValidModuleProgress(data) {
      return data.keys().hasAll(['moduleId', 'currentSection', 'totalSections', 'completed']) &&
             data.moduleId is string &&
             data.currentSection is number &&
             data.totalSections is number &&
             data.completed is bool;
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['score', 'total', 'correct', 'timestamp', 'system', 'species']) &&
             data.score is number &&
             data.total is number &&
             data.correct is number &&
             data.system is string &&
             data.species is string;
    }

    function isValidQuestion(data) {
      return data.question is string && data.question.size() < 2000 &&
             data.options is list && data.options.size() >= 2 &&
             data.correctAnswer is int &&
             data.explanation is string &&
             data.species is list &&
             data.system is string;
    }

    // --- Collection Routes ---

    // Users and their private data
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'specialty', 'institution', 'progress', 'quizStats', 'subscriptionPlan', 'subscriptionUntil']));

      match /flashcardProgress/{cardId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidFlashcardProgress(incoming());
        allow delete: if isAdmin();
      }
      
      match /moduleProgress/{moduleId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidModuleProgress(incoming());
        allow delete: if isAdmin();
      }

      match /quizHistory/{quizId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidQuizResult(incoming());
        allow update, delete: if isAdmin();
      }

      match /completedPracticeQuestions/{questionId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && 
          incoming().keys().hasAll(['questionId', 'completedAt']) &&
          incoming().questionId == questionId;
        allow delete: if isAdmin();
      }
    }

    // Global Question Pool
    match /questions/{questionId} {
      allow get, list: if isSignedIn();
      allow create: if (isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid)) && isValidQuestion(incoming());
      allow update: if (isAdmin() || (isSignedIn() && existing().get('userId', null) == request.auth.uid)) && isValidQuestion(incoming());
      allow delete: if isAdmin() || (isSignedIn() && existing().get('userId', null) == request.auth.uid);
    }

    // Global Flashcards
    match /flashcards/{cardId} {
      allow get, list: if isSignedIn();
      allow create: if (isSignedIn() && incoming().userId == request.auth.uid) || isAdmin();
      allow update, delete: if (isSignedIn() && (existing().get('userId', null) == request.auth.uid || isAdmin()));
    }

    // Study Modules
    match /modules/{moduleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // PDF Library
    match /pdfs/{pdfId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
    }

    // Guidelines and Resources
    match /guidelines/{guideId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /resources/{resId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Global Settings
    match /settings/{settingId} {
      allow get: if true;
      allow list: if isSignedIn() || isAdmin();
      allow write: if isAdmin();
    }

    // Admin Access
    match /admins/{adminId} {
      allow get, list: if isSignedIn();
      allow write: if request.auth.token.email == 'sravan96mufc@gmail.com';
    }
  }
}
